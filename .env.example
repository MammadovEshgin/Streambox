EXPO_PUBLIC_TMDB_PROXY_BASE_URL=https://your-tmdb-proxy.example.com/3
# Keep TMDB keys in the Cloudflare Worker secret store for production builds.
# EXPO_PUBLIC_TMDB_API_KEY and EXPO_PUBLIC_TMDB_ACCESS_TOKEN are local-development fallbacks only.
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_SUPABASE_RATINGS_FUNCTION_NAME=external-ratings
EXPO_PUBLIC_STREAMBOX_ASSET_BASE_URL=https://assets.streamboxapp.stream
EXPO_PUBLIC_ENABLE_LIST_EXTERNAL_RATINGS=0
EXPO_PUBLIC_ENABLE_TELEMETRY=1
EXPO_PUBLIC_GOOGLE_AUTH_WEB_CLIENT_ID=your_google_web_client_id_here
EXPO_PUBLIC_GOOGLE_AUTH_IOS_CLIENT_ID=your_google_ios_client_id_here
GOOGLE_AUTH_IOS_URL_SCHEME=com.googleusercontent.apps.your_ios_reversed_client_id
STREAMBOX_IOS_BUNDLE_IDENTIFIER=com.yourcompany.streambox
STREAMBOX_ANDROID_PACKAGE=com.yourcompany.streambox
# Set OMDB_API_KEY as a Supabase Edge Function secret.
# Do not expose the OMDb key in Expo public env vars.

# Watch Together (runtime 1.2.0): endpoint of the Cloudflare Worker that mints
# short-lived TURN credentials (workers/turn-credentials). The client fetches
# ICE servers from here at call setup — the long-lived Cloudflare TURN Token
# secret stays server-side in the Worker, never in the app bundle.
EXPO_PUBLIC_TURN_CREDENTIALS_URL=https://your-turn-worker.example.workers.dev/ice
